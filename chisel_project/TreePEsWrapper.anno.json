    "text":"\n      module BRAMBlackBoxSingle #(\n    parameter DATA = 32,\n    parameter ADDR = 10\n) (\n    input   wire               clk,\n    // Port A\n    input   wire                a_wr,\n    input   wire    [ADDR-1:0]  a_addr,\n    input   wire    [DATA-1:0]  a_din,\n    output  reg     [DATA-1:0]  a_dout,\n    // Port B\n    input   wire                b_wr,\n    input   wire    [ADDR-1:0]  b_addr,\n    input   wire    [DATA-1:0]  b_din,\n    output  reg     [DATA-1:0]  b_dout\n);\n// Shared memory\nreg [DATA-1:0] mem [(2**ADDR)-1:0];\n// Port A\nalways @(posedge clk) begin\n    a_dout      <= mem[a_addr];\n    if(a_wr) begin\n        a_dout      <= a_din;\n        mem[a_addr] <= a_din;\n    end\nend\n// Port B\nalways @(posedge clk) begin\n    b_dout      <= mem[b_addr];\n    if(b_wr) begin\n        b_dout      <= b_din;\n        mem[b_addr] <= b_din;\n    end\nend\nendmodule\n      "
